{
  "name": "whatsbotcord",
  "version": "1.0.0-beta.2",
  "author": "KristanLaimon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KristanLaimon/WhatsBotCord.js.git"
  },
  "keywords": [
    "whatsapp",
    "baileys.js",
    "bot",
    "discord",
    "automation",
    "commands",
    "command"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "fullcheck": "bun typecheck && bun lint",
    "fastest": "cross-env whatsbotcord_SKIP_LONG_TESTS=true bun test",
    "fulltest": "cross-env whatsbotcord_SKIP_LONG_TESTS=false bun test",
    "buildonly": "tsdown",
    "build_watch": "tsdown --watch",
    "build": "bun fullcheck && bun fulltest && bun run buildonly",
    "release": "bun run build && bumpp && npm publish --tag=beta",
    "try": "bun ./src/index.main.ts"
  },
  "dependencies": {
    "baileys": "7.0.0-rc.9",
    "dotenv": "17.2.1",
    "emoji-regex": "10.4.0",
    "grapheme-splitter": "1.0.4",
    "jimp": "1.6.0",
    "link-preview-js": "3.1.0",
    "mime": "4.0.7",
    "moment": "2.30.1",
    "pino": "9.9.0",
    "qr": "0.5.0",
    "sharp": "0.34.3"
  },
  "peerDependencies": {
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@eslint/js": "9.34.0",
    "@eslint/json": "0.13.2",
    "@eslint/markdown": "7.2.0",
    "@release-it/conventional-changelog": "10.0.1",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@types/bun": "1.2.20",
    "@types/mime-types": "3.0.1",
    "bumpp": "^11.0.1",
    "cross-env": "10.0.0",
    "eslint": "9.34.0",
    "globals": "16.3.0",
    "jiti": "2.5.1",
    "tsdown": "^0.21.4",
    "typescript-eslint": "8.42.0"
  },
  "trustedDependencies": [
    "baileys",
    "protobufjs"
  ]
}
